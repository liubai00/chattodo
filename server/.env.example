# Chattodo backend config
PORT=8787
HOST=127.0.0.1
DB_PATH=./data/chattodo.db
DEFAULT_USER_ID=u_default

# --- AI provider (seeds the initial ai_config row; editable later via /api/ai/config) ---
# provider: rule | openai | anthropic
#   rule      = offline rule-based triage (no key needed)
#   openai    = any OpenAI-compatible endpoint (OpenAI / DeepSeek / 通义Qwen / 豆包 / Kimi / Azure ...)
#   anthropic = Claude messages API
AI_PROVIDER=rule
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
# Fall back to the rule engine if the LLM call fails (recommended).
AI_FALLBACK_TO_RULE=true
