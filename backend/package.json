{
  "name": "@linx/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run",
    "depcruise": "depcruise --config .dependency-cruiser.cjs apps packages",
    "check": "pnpm run build && pnpm run depcruise && pnpm run test",
    "start:api": "node apps/api/dist/main.js",
    "dev:api": "tsx watch apps/api/src/main.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "dependency-cruiser": "^16.8.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.9.2",
    "vitest": "^3.0.5"
  }
}
