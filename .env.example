# ============ 服务器连接信息 ============
DEPLOY_HOST=42.192.105.250
DEPLOY_USER=root

# SSH 私钥路径（由 npm run deploy:setup-ssh 生成，勿提交 git）
DEPLOY_SSH_KEY=.ssh/chattodo_deploy

# ============ 端口配置 ============
DEPLOY_PORT=9090
DEPLOY_API_PORT=8787

# ============ 服务器路径 ============
DEPLOY_PROJECT_DIR=/opt/chattodo

# ============ 后端环境变量 ============
DEPLOY_DB_PATH=/opt/chattodo/data/chattodo.db
DEPLOY_PGLITE_DIR=/opt/chattodo/data/pgdata
DEPLOY_DEFAULT_USER_ID=u_default

# ============ 服务器 nginx 面板 (bt / native) ============
DEPLOY_NGINX_PANEL=bt

# ============ LinX × Baserow ============
# 试验环境可用 IP:端口；正式环境请改成同一主域下的 HTTPS 子域名。
TASK_BACKEND=baserow
LINX_PUBLIC_URL=http://127.0.0.1:9090
LINX_PARENT_ORIGIN=http://127.0.0.1:9090
LINX_BIND_ADDRESS=127.0.0.1
LINX_WEB_PORT=9090
BASEROW_PUBLIC_URL=http://127.0.0.1:8090
BASEROW_BIND_ADDRESS=127.0.0.1
BASEROW_PORT=8090

# 必须为至少 32 字符的随机值，并同时提供给 LinX API 与 Baserow 插件。
# 生成示例：openssl rand -hex 32
BASEROW_SHARED_SECRET=replace-with-at-least-32-random-characters

# 生产环境请替换；该端口不对公网开放。
LINX_POSTGRES_PASSWORD=replace-with-a-long-random-password
